    "InfoScreen2Subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Select one or several photos from the gallery view, click on save, and Renard will convert the selected images to HEIF and save them in your gallery. Afterward, you will have the option to delete the original image to avoid having two identical photos."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selecciona una o varias fotos desde la vista de galería, da clic en guardar y Renard convertirá las imágenes seleccionadas a HEIF, y las guardará en tu galería. Después te dará la opción de eliminar la imagen original para evitar tener dos fotos iguales."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selecciona una o varias fotos desde la vista de galería, da clic en guardar y Renard convertirá las imágenes seleccionadas a HEIF, y las guardará en tu galería. Después te dará la opción de eliminar la imagen original para evitar tener dos fotos iguales."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "갤러리 뷰에서 하나 이상의 사진을 선택한 후 저장을 클릭하면 Renard가 선택한 이미지를 HEIF로 변환하여 갤러리에 저장합니다. 그 후에는 동일한 사진 두 장이 중복되는 것을 피하기 위해 원본 이미지를 삭제할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selecione uma ou várias fotos na visualização da galeria, clique em salvar e o Renard converterá as imagens selecionadas para HEIF e as salvará na sua galeria. Em seguida, você terá a opção de excluir a imagem original para evitar ter duas fotos idênticas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selecione uma ou várias fotos na vista de galeria, clique em guardar e o Renard irá converter as imagens selecionadas para HEIF e guardá-las na sua galeria. Posteriormente, terá a opção de eliminar a imagem original para evitar ter duas fotos idênticas."
          }
        }
      }
    },
