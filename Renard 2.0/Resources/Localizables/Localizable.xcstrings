    "InfoScreen1Subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renard allows you to convert images from your gallery to the HEIF format, significantly reducing the image's file size without compromising quality and preserving all its metadata (location, date and time, camera information, parameters)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renard pemite convertir las imágenes de tu galería a formato HEIF, reduciendo considerablemente el peso de la imagen sin comprometer la calidad y conservando todos sus metadatos (ubicación, fecha y hora, información de la cámara, parámetros)."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renard pemite convertir las imágenes de tu galería a formato HEIF, reduciendo considerablemente el peso de la imagen sin comprometer la calidad y conservando todos sus metadatos (ubicación, fecha y hora, información de la cámara, parámetros)."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renard를 사용하여 갤러리의 이미지를 HEIF 형식으로 변환하여 이미지 파일 크기를 크게 줄이고 품질을 저해하지 않으면서 위치, 날짜 및 시간, 카메라 정보, 매개변수 등 모든 메타데이터를 보존할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Renard permite converter imagens da sua galeria para o formato HEIF, reduzindo significativamente o tamanho do arquivo da imagem sem comprometer a qualidade e preservando todos os metadados (localização, data e hora, informações da câmera, parâmetros)."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Renard permite-lhe converter imagens da sua galeria para o formato HEIF, reduzindo significativamente o tamanho do ficheiro da imagem sem comprometer a qualidade e preservando todos os metadados (localização, data e hora, informações da câmara, parâmetros)."
          }
        }
      }
    },
